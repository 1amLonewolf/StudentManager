# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database (SQLite for local, PostgreSQL for production)
DATABASE_URL=sqlite:///studentmanager.db

# SMS Configuration (Twilio Free Trial)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email Configuration (Gmail SMTP - Free)
# To get Gmail App Password: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-email@gmail.com  # Your Gmail address
MAIL_PASSWORD=your-app-password     # Gmail App Password (not regular password)
MAIL_DEFAULT_SENDER=your-email@gmail.com
MAIL_ADMIN=admin@example.com

# WhatsApp Settings (Click-to-Chat - Free)
WHATSAPP_ENABLED=true
WHATSAPP_COUNTRY_CODE=254  # Kenya (change as needed: 254=Kenya, 234=Nigeria, 27=SA)

# Application Settings
COURSE_FEE=4000
COURSE_NAME=Computer Packages
COURSE_DURATION_MONTHS=2

# Default Admin Credentials (CHANGE IN PRODUCTION!)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# Certificate Settings
CERTIFICATE_TEMPLATE_PATH=static/certificates/template.png
OUTPUT_CERTIFICATE_PATH=static/certificates/generated

# Pagination
STUDENTS_PER_PAGE=10
