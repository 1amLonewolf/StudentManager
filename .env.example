# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database (SQLite for local, PostgreSQL for production)
DATABASE_URL=sqlite:///studentmanager.db

# SMS Configuration (Twilio Free Trial)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Application Settings
CERTIFICATE_TEMPLATE_PATH=static/certificates/template.png
OUTPUT_CERTIFICATE_PATH=static/certificates/generated
